# LINE Messaging API のチャネルアクセストークン
# LINE Developers > チャネル > Messaging API設定 > チャネルアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=ここにトークンを貼り付け

# Google スプレッドシートの ID
# URL の https://docs.google.com/spreadsheets/d/【この部分】/edit のID
GOOGLE_SHEET_ID=ここにスプレッドシートIDを貼り付け

# シートの GID（省略可、通常は 0 のままでOK）
# 複数シートがある場合はURLの ?gid=【この数字】 を確認
GOOGLE_SHEET_GID=0
