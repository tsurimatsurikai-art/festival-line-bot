# LINE Messaging API のチャネルアクセストークン
# LINE Developers > チャネル > Messaging API設定 > チャネルアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=ここにトークンを貼り付け

# Google スプレッドシートの ID（/d/【ここ】/edit の部分だけでも、ブラウザの URL 全体でも可）
GOOGLE_SHEET_ID=ここにスプレッドシートIDまたはURLを貼り付け

# シートの GID（省略可、通常は 0 のままでOK）
# 複数シートがある場合は URL の #gid=数字 または ?gid=数字 を確認（半角数字のみ）
GOOGLE_SHEET_GID=0

# 送信形式: flex（既定・カード風）| text（プレーンテキスト）| image（画像のみ）
# LINE_NOTIFY_DELIVERY=flex

# 画像も送る場合（Messaging API では公開 HTTPS URL が必須。Canva 等で作った画像をアップロードした URL）
# LINE_NOTIFY_IMAGE_ORIGINAL_URL=https://example.com/festival-card.png
# LINE_NOTIFY_IMAGE_PREVIEW_URL=https://example.com/festival-card-preview.png

# countdown 専用: 画像 URL テンプレート（{days}, {sendDate}, {sendDateEncoded} を展開）
# - 基準日は毎年 10/17。100日以上ある場合は 99 で固定
# - sendDate は「4月26日(日)」形式
# LINE_NOTIFY_COUNTDOWN_IMAGE_ORIGINAL_URL_TEMPLATE=https://example.com/countdown.png?days={days}&date={sendDateEncoded}
# LINE_NOTIFY_COUNTDOWN_IMAGE_PREVIEW_URL_TEMPLATE=https://example.com/countdown-preview.png?days={days}&date={sendDateEncoded}

# カウントダウン画像の自動生成で使うベース画像 URL（既定あり）
# COUNTDOWN_TEMPLATE_IMAGE_URL=https://example.com/countdown-template.png
# COUNTDOWN_IMAGE_OUTPUT_PATH=assets/generated/countdown.png
#
# GitHub Actions の countdown: 生成画像を ImgBB に上げるための API key（.env は基本ローカル用。CI は GitHub Secret）
# https://api.imgbb.com/
# IMGBB_API_KEY=ここにAPIキー

# Flex が LINE で 400 になるときのテキスト自動再送を止める（デバッグ用）
# LINE_NOTIFY_NO_FLEX_FALLBACK=1

# 1 にすると LINE を送らず、取得件数だけ確認（トークン不要でシートだけ試すとき）
# LINE_NOTIFY_DRY_RUN=1
